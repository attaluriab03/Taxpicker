# ============================================================
# Taxpicker — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git — it is in .gitignore.
# ============================================================

# ------------------------------------------------------------
# Supabase — https://supabase.com/dashboard
# Found in: Project Settings → API
# ------------------------------------------------------------

# Your Supabase project URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Supabase service role / secret key (SERVER-SIDE ONLY — never expose in browser)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# ------------------------------------------------------------
# Anthropic API — https://console.anthropic.com
# Used for AI Auto-Fill in the admin CMS
# SERVER-SIDE ONLY — never expose in browser
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ------------------------------------------------------------
# Site URL — used for canonical URLs, OG tags, sitemap
# In development: http://localhost:3000
# In production: https://yourdomain.com
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
